PORT=5000
MONGO_URI=mongodb://localhost:27017/Code-Expo
JWT_SECRET=your_jwt_secret_here

# RapidAPI/Judge0 configuration for compiler
RAPID_API_KEY=your_rapid_api_key_here
RAPID_API_HOST=judge0-ce.p.rapidapi.com
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com/submissions

# Google OAuth Configuration
GOOGLE_LOGIN_CLIENT_ID=your_google_login_client_id.apps.googleusercontent.com

# Gemini AI API Key (optional for chatbot features)
GEMINI_API_KEY=your_gemini_api_key_here

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="CodeExpo" <noreply@codeexpo.com>

# Frontend URL
FRONTEND_URL=http://localhost:5173
